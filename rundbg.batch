#!/bin/bash
#SBATCH --job-name=pelec_combustor
#SBATCH --output=orun.%j
#SBATCH --error=pelec_combustor.%j.err
#SBATCH --nodes=10
#SBATCH --ntasks-per-node=48
#SBATCH --time=1:00:00
#SBATCH --mem=360G
#SBATCH --mail-user=jaystandridge@tamu.edu
#SBATCH --mail-type=ALL           


module purge
module load GCC/12.2.0 OpenMPI/4.1.4

export OMP_NUM_THREADS=1

EXE=$(ls *.ex | head -n 1)

mpirun -np 480 ./$EXE combustor_h2_dbg.inp
